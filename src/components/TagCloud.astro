---
// 顯示所有標籤及其文章計數的標籤雲組件
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface TagCount {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  maxTags?: number;
  tags?: TagCount[];
}

const { maxTags = 20, tags: incomingTags } = Astro.props;

let tags: TagCount[] = [];

if (incomingTags && incomingTags.length > 0) {
  tags = incomingTags.slice(0, maxTags);
} else {
  // 從所有文章中收集所有標籤及其計數
  const allPosts = await getCollection('blog');
  const tagMap = new Map<string, number>();

  allPosts.forEach((post: CollectionEntry<'blog'>) => {
    const tags = post.data.tags || [];
    tags.forEach((tag) => {
      tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
    });
  });

  tags = Array.from(tagMap.entries())
    .map(([name, count]) => ({
      name,
      slug: name.toLowerCase().replace(/\s+/g, '-'),
      count,
    }))
    .sort((a, b) => b.count - a.count)
    .slice(0, maxTags);
}

// 計算最大和最小計數用於調整字體大小
const maxCount = Math.max(...tags.map((t) => t.count));
const minCount = Math.min(...tags.map((t) => t.count));
const countRange = maxCount - minCount || 1;

// 根據計數計算字體大小（0.8rem ~ 1.4rem）
function getTagSize(count: number): string {
  const normalized = (count - minCount) / countRange;
  const size = 0.8 + normalized * 0.6;
  return `${size}rem`;
}
---

<div class="tag-cloud">
  <h3>標籤</h3>
  <div class="cloud">
    {tags.map((tag) => (
      <a
        href={`/blog/tags/${tag.slug}`}
        class="tag"
        style={`font-size: ${getTagSize(tag.count)}`}
        title={`${tag.count} 篇文章`}
      >
        {tag.name}
      </a>
    ))}
  </div>
</div>

<style>
  .tag-cloud {
    padding: 1.5rem;
    background-color: rgba(var(--accent), 0.03);
    border-radius: 12px;
    margin: 2rem 0;
  }

  .tag-cloud h3 {
    display: flex;
    justify-content: center; /* 水平置中 */
    margin: 0 0 1rem 0;
    color: rgb(var(--black));
    font-size: 1.125rem;
  }

  .cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }

  .tag {
    display: inline-block;
    padding: 0.5rem 0.75rem;
    color: rgb(var(--accent));
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag:hover {
    color: rgb(var(--black));
    transform: scale(1.1);
  }
</style>
