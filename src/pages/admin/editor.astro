---
// src/pages/admin/editor.astro
import { env } from "cloudflare:workers";

// 1. 引入 Astro 範本預設的共用組件 (路徑請根據你的資料夾結構確認，通常是這樣)
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleForm from '../../components/ArticleForm.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

let message = "";
const ADMIN_PWD = env.ADMIN_PASSWORD; // 從雲端環境變數抓密碼
const db = env.anneiupolan_blog_db;

async function upsertTags(articleId: number, tags: string[]) {
  for (const tag of tags) {
    const slug = tag.toLowerCase().replace(/\s+/g, '-');
    await db.prepare(
      "INSERT OR IGNORE INTO Tags (Name, Slug) VALUES (?, ?)"
    ).bind(tag, slug).run();

    const tagRecord = await db.prepare(
      "SELECT Id FROM Tags WHERE Slug = ?"
    ).bind(slug).first<{ Id: number }>();

    if (tagRecord?.Id) {
      await db.prepare(
        "INSERT OR IGNORE INTO ArticleTags (ArticleId, TagId) VALUES (?, ?)"
      ).bind(articleId, tagRecord.Id).run();
    }
  }
}

// 1. 檢查 Cookie 是否已經驗證過
const authCookie = Astro.cookies.get('admin_auth')?.value;
let isAuthenticated = !!ADMIN_PWD && authCookie === ADMIN_PWD;

// 2. 處理各種 POST 請求
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action");

  // A. 處理登入驗證
  if (action === "login") {
    const password = formData.get("password")?.toString();
    if (password === ADMIN_PWD) {
      // 驗證成功，存入 Cookie (設定有效期限為 7 天)
      Astro.cookies.set('admin_auth', password as string, { path: '/', maxAge: 60 * 60 * 24 * 7 });
      isAuthenticated = true;
    } else {
      message = "❌ 暗號毋著喔，閣試一擺！";
    }
  } 
  
  // B. 處理文章發布 (只有驗證過的人才能跑這段)
  else if (action === "publish" && isAuthenticated) {
    try {
      const title = formData.get("title")?.toString();
      const slug = formData.get("slug")?.toString();
      const heroImage = formData.get("heroImage")?.toString() || "";
      const content = formData.get("content")?.toString();
      const rawTags = formData.get("tags")?.toString() || "";
      const tags = rawTags
        .split(',')
        .map((item) => item.trim())
        .filter((item) => item.length > 0);

      if (!title || !slug || !content) {
        message = "❌ 標題、網址路徑佮內容三項攏愛有！";
      } else {
        // 在 INSERT 語法中加入 UpdatedAt
        const now = new Date().toISOString();

        const result = await db.prepare(
          "INSERT INTO Articles (Title, Slug, HeroImage, Content, IsPublished, CreatedAt, UpdatedAt) VALUES (?, ?, ?, ?, 1, ?, ?)"
        ).bind(title, slug, heroImage, content, now, now).run();

        const articleId = result.lastInsertRowId as number | undefined;

        if (articleId) {
          await upsertTags(articleId, tags);
          message = "🎉 文章新增成功！";
        } else {
          message = "❌ 寫入資料庫失敗。";
        }
      }
    } catch (error) {
      console.error(error);
      message = `發生錯誤：${error instanceof Error ? error.message : '未知錯誤'}`;
    }
  }
}
---



<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
	</head>
	<body>
		<Header />
    <main class="admin-container">
      <style>
        .admin-container { 
          max-width: 800px; 
          margin: 2rem auto; 
          padding: 0 1rem; 
        }
        .login-box {
          text-align: center;
        }
        .password { 
          width: 220px; 
          margin: 0 0 1rem; 
          color: rgb(var(--gray));
          padding: 0.75rem;
          border: 1px solid #ccc;
          border-radius: 6px;
        }
        .primary-btn {
          background-color: #2b6cb0;
          color: white;
          padding: 0.6rem 1.1rem;
          border-radius: 6px;
          text-decoration: none;
          display: inline-block;
          font-weight: bold;
          border: none;
          cursor: pointer;
        }
        .primary-btn:hover { background-color: #1a365d; }
        .alert { 
          padding: 1rem; 
          margin-bottom: 1.5rem; 
          border-radius: 6px; 
          background-color: #ebf8ff; 
          border: 1px solid #bee3f8; 
          color: #2b6cb0;
        }
      </style>

      {message && <div class="alert">{message}</div>}

      {!isAuthenticated ? (
        <div class="login-box">
          <h1>🔐 遮是私人ê後台</h1>
          <p>請key管理員暗號</p>
          <form method="POST">
            <input type="hidden" name="action" value="login" />
            <input type="password" class="password" name="password" placeholder="暗號..." required />
            <br />
            <button type="submit" class="primary-btn">進入</button>
          </form>
        </div>
      ) : (
        <ArticleForm mode="new" />
      )}
		<Footer />
	</body>
</html>
    