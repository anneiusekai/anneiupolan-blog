---
// src/pages/admin/edit/[slug].astro
import { env } from "cloudflare:workers";

import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import WebComponents from '../../../components/WebComponents.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const { slug } = Astro.params;
const db = env.anneiupolan_blog_db;
let message = "";

async function upsertTags(articleId: number, tags: string[]) {
  for (const tag of tags) {
    const slug = tag.toLowerCase().replace(/\s+/g, '-');
    await db.prepare(
      "INSERT OR IGNORE INTO Tags (Name, Slug) VALUES (?, ?)"
    ).bind(tag, slug).run();

    const tagRecord = await db.prepare(
      "SELECT Id FROM Tags WHERE Slug = ?"
    ).bind(slug).first<{ Id: number }>();

    if (tagRecord?.Id) {
      await db.prepare(
        "INSERT OR IGNORE INTO ArticleTags (ArticleId, TagId) VALUES (?, ?)"
      ).bind(articleId, tagRecord.Id).run();
    }
  }
}

// 1. 權限檢查
if (Astro.cookies.get('admin_auth')?.value !== env.ADMIN_PASSWORD) return Astro.redirect('/admin/editor');

// 3. 獲取舊資料 (用來填入表單)
const article = await db.prepare("SELECT * FROM Articles WHERE Slug = ?").bind(slug).first();
if (!article) return Astro.redirect('/admin/manage');

// 2. 處理更新請求 (POST)
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const title = formData.get("title")?.toString();
  const newSlug = formData.get("newSlug")?.toString();
  const content = formData.get("content")?.toString();
  const heroImage = formData.get("heroImage")?.toString() || "";
  const rawTags = formData.get("tags")?.toString() || "";
  const tags = rawTags
    .split(',')
    .map((item) => item.trim())
    .filter((item) => item.length > 0);

  try {
    // 只更新 UpdatedAt，保留 CreatedAt
    const now = new Date().toISOString();

    await db.prepare(
      "UPDATE Articles SET Title = ?, Slug = ?, Content = ?, HeroImage = ?, UpdatedAt = ? WHERE Slug = ?"
    ).bind(title, newSlug, content, heroImage, now, slug).run();

    if (article?.Id) {
      await db.prepare(
        "DELETE FROM ArticleTags WHERE ArticleId = ?"
      ).bind(article.Id).run();

      await upsertTags(article.Id, tags);
    }
    
    // 如果連網址路徑 (Slug) 都改了，要跳轉到新的編輯網址
    if (newSlug !== slug) return Astro.redirect(`/admin/edit/${newSlug}?success=1`);
    message = "✅ 修改成功！";
  } catch (e) {
    message = "❌ 更新失敗：" + (e instanceof Error ? e.message : "未知錯誤");
  }
}

// 如果是跳轉回來的，顯示成功訊息
if (Astro.url.searchParams.get('success')) message = "✅ 修改成功！";

const { results } = await db.prepare(
  "SELECT t.Name FROM Tags t JOIN ArticleTags at ON at.TagId = t.Id JOIN Articles a ON a.Id = at.ArticleId WHERE a.Slug = ?"
).bind(slug).all<{ Name: string }>();

const articleTagRows = results as { Name: string }[];
const existingTags = articleTagRows.map((row) => row.Name);
const tagsValue = existingTags.join(', ');
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
	</head>
	<body>
		<Header />
    <main class="admin-container">
      <style>
        /* 3. 保留表單專用的 CSS，讓輸入框跟按鈕在主框架下依然好看 */
        .admin-container { 
          max-width: 800px; 
          margin: 2rem auto; 
          padding: 0 1rem; 
        }
        .form-group { margin-bottom: 1.5rem; }
        label { 
          display: block; 
          margin-bottom: 0.5rem; 
          font-weight: bold; 
          color: var(--black); /* 使用 Astro 預設主題的變數 */
        }
        input[type="text"], textarea { 
          width: 100%; 
          padding: 0.75rem; 
          border: 1px solid #ccc; 
          border-radius: 6px; 
          font-family: inherit;
          font-size: 1rem;
        }
        button { 
          background-color: #2b6cb0; 
          color: white; 
          padding: 0.75rem 1.5rem; 
          border: none; 
          border-radius: 6px; 
          cursor: pointer; 
          font-size: 1rem;
          font-weight: bold;
          transition: background-color 0.2s;
        }
        button:hover { background-color: #1a365d; }
        .alert { 
          padding: 1rem; 
          margin-bottom: 1.5rem; 
          border-radius: 6px; 
          background-color: #ebf8ff; 
          border: 1px solid #bee3f8; 
          color: #2b6cb0;
        }
      </style>

      {message && <div class="alert">{message}</div>}


      <form method="POST">
        <h1>📝 修改舊文章</h1>
        <div class="form-group">
          <label for="title">文章標題</label>
          <input type="text" id="title" name="title" value={article.Title} placeholder="例如：我ê頭一篇" required />
        </div>

        <div class="form-group">
          <label for="slug">網址路徑（Slug）（著愛是Lô-má字佮數字ê組合）</label>
          <input type="text" id="slug" name="newSlug" value={article.Slug} placeholder="例如：my-first-article" required />
        </div>

        <div class="form-group">
          <label for="heroImage">封面圖片 R2 網址（選填）</label>
          <input type="text" id="heroImage" name="heroImage" value={article.HeroImage} placeholder="https://img.yourdomain.com/photo.jpg" />
        </div>

        <div class="form-group">
          <label for="tags">標籤（用逗號分隔）</label>
          <input type="text" id="tags" name="tags" value={tagsValue} placeholder="例如：Poland, Food, Travel" />
          <p style="margin: 0.5rem 0 0; color: rgb(var(--gray)); font-size: 0.9rem;">輸入多個標籤時請用逗號分隔。</p>
        </div>

        <div class="form-group">
          <label for="content">文章內容（支援 Markdown 佮 HTML 組件）</label>          
          <!--
          <textarea id="content" name="content" rows="15" required placeholder='嘛有支援<taigi-gloss>這个註解標籤喔！\n親像：<taigi-gloss data-definition="解說">較難ê詞</taigi-gloss>'></textarea>
          -->
          <textarea id="content" name="content">{article.Content}</textarea>
        </div>

        <button type="submit">💾 儲存修改</button>
      </form>
      <WebComponents />
      <script>
        // A. 將原本陽春的 textarea 升級為 EasyMDE 編輯器
        const EasyMDE = (window as any).EasyMDE;
        const easymde = new EasyMDE({ 
          element: document.getElementById('content'),
          spellChecker: false, // 建議關閉，避免中文/台語拼音被畫上紅色的錯誤底線
          autosave: {
            enabled: true, // 開啟自動暫存功能 (存在瀏覽器 LocalStorage)
            // 故意不設 uniqueId 
            delay: 3000,
          },
          placeholder: '會用得揤「目睭」預覽看覓仔！\n\n嘛有支援<taigi-gloss>這个註解標籤喔！\n親像：<taigi-gloss data-ruby="hoat-im" data-definition="解說">較難ê詞</taigi-gloss>'
        });

      </script>
    </main>
		<Footer />
	</body>
</html>