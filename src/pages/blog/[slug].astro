---
// src/pages/blog/[slug].astro
import type { CollectionEntry } from 'astro:content';
import { env } from "cloudflare:workers";
import { getCollection } from 'astro:content';
// 1. 引入原本的 Layout 組件 (就像引入 _Layout.cshtml)
import BlogPost from '../../layouts/BlogPost.astro';
import WebComponents from '../../components/WebComponents.astro';
import TagList from '../../components/TagList.astro';
import Comments from '../../components/Comments.astro';

const authCookie = Astro.cookies.get('admin_auth')?.value;
const isAdmin = !!env.ADMIN_PASSWORD && authCookie === env.ADMIN_PASSWORD;

const { slug } = Astro.params;
let article = null;
let errorMessage = "";
let postTags: string[] = [];

try {
  const db = env.anneiupolan_blog_db;
  article = await db.prepare(
    "SELECT * FROM Articles WHERE Slug = ? AND IsPublished = 1"
  ).bind(slug).first();
  
  // 從 Content Collections 取得 tags
  const allBlogPosts = await getCollection('blog');
  const blogPost = allBlogPosts.find((post: CollectionEntry<'blog'>) => post.id.split('/')[0] === slug);

  const { results } = await db.prepare(
    "SELECT t.Name FROM Tags t JOIN ArticleTags at ON at.TagId = t.Id JOIN Articles a ON a.Id = at.ArticleId WHERE a.Slug = ? AND a.IsPublished = 1"
  ).bind(slug).all<{ Name: string }>();

  const tagRows = results as { Name: string }[];
  const dbTags = tagRows.map((row) => row.Name);

  if (blogPost) {
    const collectionTags = blogPost.data.tags || [];
    postTags = Array.from(new Set([...collectionTags, ...dbTags]));
  } else {
    postTags = dbTags;
  }
} catch (error) {
  errorMessage = error instanceof Error ? error.message : "未知錯誤";
}

if (!article && !errorMessage) {
  return new Response("揣無這篇文章 (404 Not Found)", { status: 404 });
}
---

{/* 如果有報錯，顯示簡單的錯誤畫面 */}
{errorMessage ? (
  <html lang="zh-TW">
    <body>
      <div style="color: red; padding: 20px;">
        <h1>🔥 伺服器錯誤 (500)</h1>
        <p>{errorMessage}</p>
      </div>
    </body>
  </html>
) : (
  /* 2. 使用 BlogPost 組件包覆內容！
       把從資料庫撈出來的資料 (article) 對應到 Layout 需要的屬性 (Props) 上 
  */
  <BlogPost
    title={article.Title}
    description={article.Title}
    pubDate={new Date(article.CreatedAt)}
    updatedDate={new Date(article.UpdatedAt)}
    heroImage={article.HeroImage}
    tags={postTags}
  >
    {/* 3. 這裡就是文章的本體，會被自動塞進 Layout 的 <slot /> 裡面 */}
    <div class="prose" set:html={article.Content}></div>

    {isAdmin && (
      <p style="margin-top: 2rem;">
        <a href={`/admin/edit/${article.Slug}`} class="admin-edit-btn">修改文章</a>
      </p>
    )}

    {/* 4. 把我們寫的 Web Component 腳本放在這裡，讓 <taigi-gloss> 繼續生效 */}
    <WebComponents />

    {/* 新增：顯示標籤列表 */}
    {postTags.length > 0 && (
      <TagList tags={postTags} class="article-tags" />
    )}

    {/* 新增：留言功能 */}
    <Comments articleId={article.Id} />

  </BlogPost>
)}

<style is:global>
  .article-tags {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--gray), 0.3);
  }
  .admin-edit-btn {
    display: inline-block;
    padding: 0.75rem 1rem;
    background: var(--accent);
    color: white;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }
</style>