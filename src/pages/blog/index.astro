---
// 1. 引入 Cloudflare 環境變數
import type { CollectionEntry } from 'astro:content';
import { env } from "cloudflare:workers";
import { getCollection } from 'astro:content';

import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagCloud from '../../components/TagCloud.astro';
import TagList from '../../components/TagList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

type ArticleRow = {
  Title: string;
  Slug: string;
  HeroImage: string;
  CreatedAt: string;
};

type ArticleTagRow = {
  Slug: string;
  Name: string;
};

// 2. 建立資料庫連線
const db = env.anneiupolan_blog_db;

// 3. 撈取所有已發布的文章，並依照建立時間 (CreatedAt) 由新到舊排序 (DESC)
const { results: posts } = await db.prepare(
  "SELECT Title, Slug, HeroImage, CreatedAt FROM Articles WHERE IsPublished = 1 ORDER BY CreatedAt DESC"
).all<ArticleRow>();

const { results } = await db.prepare(
  "SELECT a.Slug, t.Name FROM Articles a JOIN ArticleTags at ON at.ArticleId = a.Id JOIN Tags t ON t.Id = at.TagId WHERE a.IsPublished = 1"
).all<ArticleTagRow>();

const articleTagRows = results as ArticleTagRow[];
const dbTagsMap = new Map<string, string[]>();
articleTagRows.forEach((row) => {
  const existing = dbTagsMap.get(row.Slug) || [];
  dbTagsMap.set(row.Slug, Array.from(new Set([...existing, row.Name])));
});

// 4. 從 Content Collections 取得所有文章及其 tags
const allBlogPosts = await getCollection('blog');

// 5. 創建一個 slug 到 tags 的映射
const postTagsMap = new Map<string, string[]>();
allBlogPosts.forEach((post: CollectionEntry<'blog'>) => {
  const slug = post.id.split('/')[0]; // 取得檔案名稱（不含 collection 路徑）
  postTagsMap.set(slug, post.data.tags || []);
});

// 6. 將數據庫文章資訊與 tags 結合
const postsWithTags: Array<ArticleRow & { tags: string[] }> = posts.map((post: ArticleRow) => {
  const dbTags = dbTagsMap.get(post.Slug) || [];
  const collectionTags = postTagsMap.get(post.Slug) || [];
  const tags = Array.from(new Set([...collectionTags, ...dbTags]));

  return {
    ...post,
    tags,
  };
});

const tagCountMap = new Map<string, number>();
postsWithTags.forEach((post: { tags: string[] }) => {
  post.tags.forEach((tag: string) => {
    tagCountMap.set(tag, (tagCountMap.get(tag) || 0) + 1);
  });
});

const tagCounts = Array.from(tagCountMap.entries())
  .map(([name, count]) => ({
    name,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
    count,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 20);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li:first-child .tag-list {
				width: 100%;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				/* 加入 object-fit 確保圖片比例不會因為外部連結而變形 */
				object-fit: cover;
				aspect-ratio: 2 / 1;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{/* 顯示標籤雲 */}
				<TagCloud tags={tagCounts} />
				
				<ul>
					{
						postsWithTags.map((post: ArticleRow & { tags: string[] }) => (
							<li>
								{/* 4. 把 post.id 換成我們資料庫裡的 post.Slug */}
								<a href={`/blog/${post.Slug}/`}>
									
									{/* 5. 圖片來源改成 post.HeroImage，並使用原生 img 標籤 */}
									{post.HeroImage && (
										<img width="720" height="360" src={post.HeroImage} alt={`封面圖：${post.Title}`} />
									)}
									
									{/* 6. 綁定標題 */}
									<h4 class="title">{post.Title}</h4>
									
									<p class="date">
										{/* 7. 把資料庫的字串時間轉換為 Date 物件，交給組件格式化 */}
										<FormattedDate date={new Date(post.CreatedAt)} />
									</p>
								</a>
								
								{/* 8. 新增：顯示標籤列表 */}
								{post.tags.length > 0 && (
									<TagList class="tag-list" tags={post.tags} />
								)}
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>